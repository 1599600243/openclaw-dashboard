# OpenClaw Dashboard 环境变量配置示例

# ========================
# 服务端口配置
# ========================

# CLI代理服务端口 (默认: 3002)
CLI_PROXY_PORT=3002

# 前端HTTP服务器端口 (默认: 3003)
FRONTEND_PORT=3003

# ========================
# OpenClaw CLI 配置
# ========================

# OpenClaw CLI可执行文件路径 (默认: openclaw)
# 如果OpenClaw不在PATH中，请指定完整路径
OPENCLAW_PATH=openclaw

# OpenClaw CLI命令执行超时时间 (毫秒，默认: 30000)
OPENCLAW_TIMEOUT=30000

# OpenClaw状态目录 (可选，自动检测)
# OPENCLAW_STATE_DIR=C:/Users/admin/.openclaw

# ========================
# 缓存配置
# ========================

# 缓存生存时间 (毫秒，默认: 300000 = 5分钟)
CACHE_TTL=300000

# 缓存检查间隔 (毫秒，默认: 60000 = 1分钟)
CACHE_CHECK_PERIOD=60000

# ========================
# 日志配置
# ========================

# 日志级别: error, warn, info, debug (默认: info)
LOG_LEVEL=info

# 日志文件路径 (可选，默认输出到控制台)
# LOG_FILE=./logs/dashboard.log

# ========================
# 安全配置
# ========================

# CORS允许的来源 (逗号分隔，默认: *)
# 生产环境建议设置为具体的域名
CORS_ALLOWED_ORIGINS=http://localhost:3003,http://127.0.0.1:3003

# API密钥认证 (可选)
# API_KEY=your-secret-api-key-here

# ========================
# 高级配置
# ========================

# 启用详细调试日志 (默认: false)
DEBUG=false

# 会话列表自动刷新间隔 (毫秒，默认: 60000 = 1分钟)
SESSION_REFRESH_INTERVAL=60000

# 历史消息最大数量 (默认: 50)
HISTORY_LIMIT=50

# ========================
# 使用说明
# ========================
# 1. 复制此文件为 .env
# 2. 根据需要修改配置
# 3. 启动服务时会自动加载配置
# ========================

# 示例：生产环境配置
# CLI_PROXY_PORT=3002
# FRONTEND_PORT=8080
# OPENCLAW_PATH=/usr/local/bin/openclaw
# CORS_ALLOWED_ORIGINS=https://yourdomain.com
# LOG_LEVEL=warn
# LOG_FILE=/var/log/openclaw-dashboard.log